#!/usr/bin/env bash
# agent-hud — portable two-level resource HUD for agent status lines.
#   Top level  = THIS TUI session (CPU/MEM of all procs in the session + pwd size)
#   Bottom level = whole machine  (CPU/MEM + free disk on cwd's volume)
# Subcommands: render | daemon | colorways | help
# Colorways are swappable; default is gruvbox (override: AGENT_HUD_COLORWAY or config).

set -u

OS="$(uname -s)"                            # Darwin | Linux
CG="/sys/fs/cgroup"                         # cgroup root (Linux containers)

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/agent-hud"
SYS_CACHE="$CACHE_DIR/sys"          # one line: system CPU%% (integer)
PWD_CACHE_DIR="$CACHE_DIR/pwd"      # per-cwd: "<kb> <epoch>"
HIST_DIR="$CACHE_DIR/hist"          # per-tty time-series: "<epoch> scpu smem syscpu symem"
CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/agent-hud/config"
mkdir -p "$CACHE_DIR" "$PWD_CACHE_DIR" "$HIST_DIR" 2>/dev/null

DAEMON_INTERVAL="${AGENT_HUD_INTERVAL:-2}"   # daemon sample cadence (s)
SYS_STALE=6                                  # sys cache older than this -> fallback
PWD_TTL="${AGENT_HUD_PWD_TTL:-10}"           # pwd-size cache freshness (s)
PWD_TIMEOUT="${AGENT_HUD_PWD_TIMEOUT:-0.3}"  # max blocking time for du (s)
HIST_WINDOW="${AGENT_HUD_HIST_WINDOW:-1800}" # graph time span (s) -> 30 min
HIST_STEP="${AGENT_HUD_HIST_STEP:-5}"        # min spacing between recorded samples (s)

# ---------- colorways -------------------------------------------------------
# Each sets truecolor escapes: CSESS CSYS CCPU CMEM CSTORE CDIM (and bold flag).
R=$'\033[0m'
_rgb() { printf '\033[38;2;%s;%s;%sm' "$1" "$2" "$3"; }

resolve_colorway() {
  local cw="${AGENT_HUD_COLORWAY:-}"
  if [ -z "$cw" ] && [ -f "$CONFIG" ]; then
    cw=$(awk -F= '/^colorway/{gsub(/[ \t]/,"",$2); print $2}' "$CONFIG" 2>/dev/null)
  fi
  cw=$(printf '%s' "${cw:-gruvbox}" | tr '[:upper:]' '[:lower:]' | tr -d ' ')
  SESS_BOLD=""
  # Each colorway sets RGB triples ("r g b"); escapes are derived below so the
  # graph/pie renderers can reuse the raw components (e.g. for backgrounds).
  case "$cw" in
    catppuccin|mocha|catppuccin-mocha)
      CSESS_RGB="203 166 247"; CSYS_RGB="137 180 250"
      CCPU_RGB="249 226 175";  CMEM_RGB="166 227 161"
      CSTORE_RGB="250 179 135"; CDIM_RGB="108 112 134" ;;
    tokyo|tokyonight|tokyo-night)
      CSESS_RGB="187 154 247"; CSYS_RGB="122 162 247"
      CCPU_RGB="224 175 104";  CMEM_RGB="158 206 106"
      CSTORE_RGB="255 158 100"; CDIM_RGB="86 95 137" ;;
    mono|minimal)
      CSESS_RGB="255 255 255"; CSYS_RGB="255 255 255"
      CCPU_RGB="205 214 244";  CMEM_RGB="205 214 244"
      CSTORE_RGB="205 214 244"; CDIM_RGB="88 91 112"; SESS_BOLD=$'\033[1m' ;;
    lavish)
      # opulent: amethyst + gold, neon magenta/aqua accents on a violet dim
      CSESS_RGB="244 191 79";  CSYS_RGB="199 146 234"
      CCPU_RGB="255 121 198";  CMEM_RGB="80 250 200"
      CSTORE_RGB="255 184 108"; CDIM_RGB="108 99 142" ;;
    gruvbox|*)
      CSESS_RGB="211 134 155"; CSYS_RGB="131 165 152"
      CCPU_RGB="250 189 47";   CMEM_RGB="184 187 38"
      CSTORE_RGB="254 128 25"; CDIM_RGB="146 131 116" ;;
  esac
  CSESS=$(_rgb $CSESS_RGB);   CSYS=$(_rgb $CSYS_RGB)
  CCPU=$(_rgb $CCPU_RGB);     CMEM=$(_rgb $CMEM_RGB)
  CSTORE=$(_rgb $CSTORE_RGB); CDIM=$(_rgb $CDIM_RGB)
  COLORWAY="$cw"
}

# ---------- helpers ---------------------------------------------------------
now() { date +%s; }
if [ "$OS" = Darwin ]; then
  mtime() { stat -f %m "$1" 2>/dev/null || echo 0; }
else
  mtime() { stat -c %Y "$1" 2>/dev/null || echo 0; }
fi

# ---------- cgroup helpers (Linux containers) -------------------------------
# Inside a k8s pod / Docker container, /proc/meminfo, /proc/stat and nproc all
# report the host NODE, not the container's cgroup limits. When cgroup limits
# are present we prefer them; otherwise every helper echoes nothing and the
# caller falls back to the /proc behaviour (bare metal is unaffected).
proc_mem_total() { awk '/^MemTotal:/{printf "%.0f", $2*1024}' /proc/meminfo 2>/dev/null; }

cg_v1_cpu_dir() {     # locate cgroup v1 cpu controller (mount layout varies)
  local d; for d in "$CG/cpu" "$CG/cpu,cpuacct"; do
    [ -f "$d/cpu.cfs_quota_us" ] && { printf '%s' "$d"; return; }
  done
}
cg_v1_cpuacct_dir() {
  local d; for d in "$CG/cpuacct" "$CG/cpu,cpuacct"; do
    [ -f "$d/cpuacct.usage" ] && { printf '%s' "$d"; return; }
  done
}

cgroup_mem() {        # echoes "USED TOTAL" (bytes) if memory-limited, else nothing
  local lim cur inact node
  node=$(proc_mem_total)
  if [ -f "$CG/memory.max" ] && [ -f "$CG/memory.current" ]; then            # v2
    lim=$(cat "$CG/memory.max" 2>/dev/null)
    cur=$(cat "$CG/memory.current" 2>/dev/null)
    inact=$(awk '/^inactive_file /{print $2}' "$CG/memory.stat" 2>/dev/null)
  elif [ -f "$CG/memory/memory.limit_in_bytes" ] && [ -f "$CG/memory/memory.usage_in_bytes" ]; then  # v1
    lim=$(cat "$CG/memory/memory.limit_in_bytes" 2>/dev/null)
    cur=$(cat "$CG/memory/memory.usage_in_bytes" 2>/dev/null)
    inact=$(awk '/^total_inactive_file /{print $2}' "$CG/memory/memory.stat" 2>/dev/null)
  else
    return
  fi
  case "$lim" in ''|max) return;; esac
  # Treat limit <= 0, non-numeric, or >= node RAM (the unlimited/PAGE_COUNTER_MAX
  # sentinel) as "not constrained" -> fall back to /proc. used = current minus
  # reclaimable page cache, which is closer to what k8s/OOM accounts.
  awk -v l="$lim" -v c="$cur" -v i="${inact:-0}" -v n="${node:-0}" 'BEGIN{
    if (l+0 <= 0 || (n>0 && l+0 >= n)) exit 1;
    u = c - i; if (u < 0) u = c;
    printf "%.0f %.0f", u, l }' || return
}

cgroup_cpu_cores() {  # echoes the CPU quota in cores (float) if limited, else nothing
  local q p d
  if [ -f "$CG/cpu.max" ]; then                                             # v2
    read -r q p _ < "$CG/cpu.max" 2>/dev/null
    [ "$q" = max ] && return
  else                                                                      # v1
    d=$(cg_v1_cpu_dir); [ -z "$d" ] && return
    q=$(cat "$d/cpu.cfs_quota_us" 2>/dev/null)   # -1 when unlimited
    p=$(cat "$d/cpu.cfs_period_us" 2>/dev/null)
  fi
  awk -v q="${q:-0}" -v p="${p:-0}" 'BEGIN{
    if (q+0<=0 || p+0<=0) exit 1; printf "%.4f", q/p }' || return
}

cgroup_cpu_usage_usec() {  # cumulative CPU usage in microseconds, else nothing
  local d
  if [ -f "$CG/cpu.stat" ]; then                                            # v2
    awk '/^usage_usec /{print $2}' "$CG/cpu.stat" 2>/dev/null
  else                                                                      # v1 (ns->us)
    d=$(cg_v1_cpuacct_dir); [ -z "$d" ] && return
    awk '{printf "%.0f", $1/1000}' "$d/cpuacct.usage" 2>/dev/null
  fi
}

sample_cgroup_cpu() {  # arg: quota cores. CPU-time delta over 1s, normalised by quota
  local cores="$1" u1 u2
  u1=$(cgroup_cpu_usage_usec)
  sleep 1
  u2=$(cgroup_cpu_usage_usec)
  awk -v a="${u1:-0}" -v b="${u2:-0}" -v c="$cores" 'BEGIN{
    du=b-a; win=1000000*c;          # CPU-us used vs CPU-us available in the window
    if (win<=0 || du<0) { print 0; exit }
    p=du/win*100; if(p<0)p=0; if(p>100)p=100; printf "%d", p }'
}

kb2h() { # KB -> human (M/G)
  awk -v k="$1" 'BEGIN{
    if (k < 1024) { printf "%dK", k }
    else if (k < 1048576) { printf "%.0fM", k/1024 }
    else { printf "%.1fG", k/1048576 }
  }'
}
b2h() { # bytes -> human
  awk -v b="$1" 'BEGIN{
    if (b < 1048576) { printf "%.0fM", b/1048576 }
    else { printf "%.1fG", b/1073741824 }
  }'
}

# ---------- system CPU%% -----------------------------------------------------
sys_cpu() {
  if [ -f "$SYS_CACHE" ] && [ $(( $(now) - $(mtime "$SYS_CACHE") )) -le "$SYS_STALE" ]; then
    cat "$SYS_CACHE"; return
  fi
  # fallback: load average normalised by core count
  local la ncpu
  if [ "$OS" = Darwin ]; then
    la=$(sysctl -n vm.loadavg 2>/dev/null | awk '{print $2}')
    ncpu=$(sysctl -n hw.ncpu 2>/dev/null || echo 1)
  else
    la=$(awk '{print $1}' /proc/loadavg 2>/dev/null)
    ncpu=$(cgroup_cpu_cores); [ -z "$ncpu" ] && ncpu=$(nproc 2>/dev/null || echo 1)
  fi
  awk -v la="${la:-0}" -v n="${ncpu:-1}" 'BEGIN{p=la/n*100; if(p>100)p=100; printf "%d", p}'
}

sample_sys_cpu() { # blocking ~1s; used by daemon
  if [ "$OS" = Darwin ]; then
    top -l 2 -s 1 -n 0 2>/dev/null \
      | awk '/CPU usage/{l=$0} END{ if (match(l,/([0-9.]+)% idle/)) {
          s=substr(l,RSTART,RLENGTH); gsub(/% idle/,"",s); printf "%d", 100-s } else print "0" }'
  else
    # In a container, prefer cgroup CPU-time delta normalised by the quota;
    # /proc/stat is node-scoped and would understate the pod's true CPU%.
    local cores; cores=$(cgroup_cpu_cores)
    [ -n "$cores" ] && { sample_cgroup_cpu "$cores"; return; }
    # /proc/stat delta: busy = total - idle, over a 1s window
    local r1 r2
    r1=$(awk '/^cpu /{print $2+$3+$4+$5+$6+$7+$8, $5+$6}' /proc/stat 2>/dev/null)
    sleep 1
    r2=$(awk '/^cpu /{print $2+$3+$4+$5+$6+$7+$8, $5+$6}' /proc/stat 2>/dev/null)
    awk -v a="$r1" -v b="$r2" 'BEGIN{
      na=split(a,x," "); nb=split(b,y," ");
      if (na<2 || nb<2) { print "0"; exit }
      dt=y[1]-x[1]; di=y[2]-x[2];
      if (dt<=0) { print "0" } else { p=(dt-di)/dt*100; if(p<0)p=0; if(p>100)p=100; printf "%d", p }
    }'
  fi
}

# ---------- system memory ---------------------------------------------------
sys_mem() { # echoes "USED_BYTES TOTAL_BYTES"
  if [ "$OS" = Darwin ]; then
    local ps total stats active wired comp
    ps=$(sysctl -n hw.pagesize 2>/dev/null || echo 4096)
    total=$(sysctl -n hw.memsize 2>/dev/null || echo 0)
    stats=$(vm_stat 2>/dev/null)
    active=$(printf '%s' "$stats" | awk '/Pages active/{gsub(/[^0-9]/,"",$3);print $3}')
    wired=$(printf '%s' "$stats"  | awk '/Pages wired down/{gsub(/[^0-9]/,"",$4);print $4}')
    comp=$(printf '%s' "$stats"   | awk '/occupied by compressor/{gsub(/[^0-9]/,"",$5);print $5}')
    awk -v a="${active:-0}" -v w="${wired:-0}" -v c="${comp:-0}" -v p="$ps" -v t="$total" \
      'BEGIN{ printf "%.0f %s", (a+w+c)*p, t }'
  else
    # Prefer cgroup limits inside a container; else fall back to /proc/meminfo.
    local cg; cg=$(cgroup_mem)
    [ -n "$cg" ] && { printf '%s' "$cg"; return; }
    # /proc/meminfo is in kB; used = total - available
    awk '/^MemTotal:/{t=$2} /^MemAvailable:/{a=$2} END{
      if (a=="") a=t;   # pre-3.14 kernels lack MemAvailable
      printf "%.0f %.0f", (t-a)*1024, t*1024 }' /proc/meminfo 2>/dev/null
  fi
}

# ---------- this session (CPU + MEM) ----------------------------------------
# "Session" = all processes sharing this pane's controlling tty (shell + agent +
# children). macOS ps has no numeric SID, but tty groups a TUI session cleanly.
session_tty() { # walk parents until one has a real controlling tty
  local pid=$$ tty i
  for i in 1 2 3 4 5 6 7 8; do
    tty=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d ' ')
    case "$tty" in ''|'?'|'??') : ;; *) printf '%s' "$tty"; return ;; esac
    pid=$(ps -o ppid= -p "$pid" 2>/dev/null | tr -d ' ')
    { [ -z "$pid" ] || [ "$pid" = 0 ]; } && break
  done
}

session_stats() { # echoes "CPU_INT RSS_BYTES"
  local tty; tty=$(session_tty)
  [ -z "$tty" ] && { echo "0 0"; return; }
  ps -t "$tty" -o pcpu=,rss= 2>/dev/null \
    | awk '{ cpu+=$1; rss+=$2 } END { printf "%d %.0f", cpu, rss*1024 }'
}

# ---------- pwd size (live du + timeout + async cache) ----------------------
pwd_size() { # arg: dir -> echoes human size (or "..." while warming)
  local dir="$1" key cf val ts age
  key=$(printf '%s' "$dir" | cksum | awk '{print $1}')
  cf="$PWD_CACHE_DIR/$key"
  val=""; ts=0
  if [ -f "$cf" ]; then val=$(awk '{print $1}' "$cf"); ts=$(awk '{print $2}' "$cf"); fi
  age=$(( $(now) - ${ts:-0} ))
  if [ -z "$val" ] || [ "$age" -ge "$PWD_TTL" ]; then
    # refresh in background, non-blocking; lock prevents pile-up
    if mkdir "$cf.lock" 2>/dev/null; then
      ( kb=$(du -sk "$dir" 2>/dev/null | awk '{print $1}'); \
        [ -n "$kb" ] && printf '%s %s\n' "$kb" "$(now)" > "$cf"; \
        rmdir "$cf.lock" 2>/dev/null ) &
    fi
    # give a fast dir a brief chance to populate before we give up
    local waited=0
    while [ -d "$cf.lock" ] && awk -v w="$waited" -v t="$PWD_TIMEOUT" 'BEGIN{exit !(w<t)}'; do
      sleep 0.05; waited=$(awk -v w="$waited" 'BEGIN{print w+0.05}')
    done
    [ -f "$cf" ] && val=$(awk '{print $1}' "$cf")
  fi
  if [ -n "$val" ]; then kb2h "$val"; else printf '…'; fi
}

# ---------- disk (free on cwd volume) ---------------------------------------
disk_free() { # arg: dir -> echoes "FREE_H CAP" e.g. "312G 22%"
  df -kP "$1" 2>/dev/null | awk 'NR==2{ free=$4; cap=$5; printf "%s %s", free, cap }' \
    | { read -r free cap; printf '%s %s' "$(kb2h "$free")" "$cap"; }
}

# ---------- time-series history (per session/tty) ---------------------------
# Recorded on every render, but at most one sample per HIST_STEP seconds so the
# file stays bounded and evenly spaced. Columns: epoch scpu smem% syscpu symem%.
hist_path() {
  local key; key=$(session_tty); key="${key:-default}"
  key=$(printf '%s' "$key" | cksum | awk '{print $1}')
  printf '%s/%s' "$HIST_DIR" "$key"
}
record_history() { # args: scpu smem% syscpu symem%
  local f last now_s; f=$(hist_path); now_s=$(now)
  last=0; [ -f "$f" ] && last=$(tail -n1 "$f" 2>/dev/null | awk '{print $1+0}')
  [ $(( now_s - ${last:-0} )) -lt "$HIST_STEP" ] && return
  printf '%s %s %s %s %s\n' "$now_s" "${1:-0}" "${2:-0}" "${3:-0}" "${4:-0}" >> "$f"
  # trim to the window so the file never grows without bound
  awk -v c=$(( now_s - HIST_WINDOW )) '$1+0>=c' "$f" > "$f.tmp" 2>/dev/null && mv "$f.tmp" "$f"
}
hist_col() { # arg: column index (2=scpu 3=smem 4=syscpu 5=symem) -> "t v" pairs
  local f; f=$(hist_path); [ -f "$f" ] || return
  awk -v k="$1" '{print $1, $k}' "$f"
}

# ---------- braille time-graph ----------------------------------------------
# stdin: "t v" pairs (v in 0..100+). Emits H rows of W braille cells (2x4 dots),
# an area chart with sample-and-hold across the HIST_WINDOW, "now" on the right.
braille_chart() { # args: W H now window
  awk -v W="$1" -v H="$2" -v now="$3" -v window="$4" '
    function dot(sc,sr){
      if(sc==0) return (sr==0?1:(sr==1?2:(sr==2?4:64)))
      else      return (sr==0?8:(sr==1?16:(sr==2?32:128)))
    }
    { n++; T[n]=$1+0; V[n]=$2+0 }
    END{
      if(window<=0) window=1
      PXW=2*W; PXH=4*H; t0=now-window
      for(cx=0;cx<PXW;cx++){
        ct=t0+(cx/(PXW-1))*window; val=-1
        for(i=1;i<=n;i++){ if(T[i]<=ct) val=V[i]; else break }
        if(val<0){ col[cx]=-1; continue }
        if(val>100)val=100; if(val<0)val=0; col[cx]=val
      }
      for(cx=0;cx<PXW;cx++){
        v=col[cx]; if(v<0) continue
        pyl=int((100-v)/100*(PXH-1)+0.5)
        for(py=pyl;py<PXH;py++){
          cc=int(cx/2); cr=int(py/4); G[cr SUBSEP cc]+=dot(cx%2,py%4)
        }
      }
      for(cr=0;cr<H;cr++){
        line=""
        for(cc=0;cc<W;cc++){
          cp=10240+(G[cr SUBSEP cc]+0); rem=cp%4096
          line=line sprintf("%c%c%c",224+int(cp/4096),128+int(rem/64),128+(rem%64))
        }
        print line
      }
    }'
}
_chart() { # args: col -> one-row braille sparkgraph (no color) over HIST_WINDOW
  hist_col "$1" | braille_chart "$GW" 1 "$(now)" "$HIST_WINDOW"
}
# Graph view mirrors the classic two-line layout (session row / system row),
# CPU then MEM left-to-right, but swaps each static figure for a dense braille
# time-graph of the last 30 min. Denser sampling (HIST_STEP) -> more points.
view_graph() {
  local GW="${AGENT_HUD_GRAPH_W:-16}"
  local g_sc g_sm g_yc g_ym
  g_sc=$(_chart 2); g_sm=$(_chart 3); g_yc=$(_chart 4); g_ym=$(_chart 5)
  printf '%b⊳ session%b   %bCPU%b %b%s%b %b%3s%%%b   %bMEM%b %b%s%b %b%3s%%%b\n' \
    "$SESS_BOLD$CSESS" "$R" "$CDIM" "$R" "$CCPU" "$g_sc" "$R" "$CCPU" "$s_cpu" "$R" \
    "$CDIM" "$R" "$CMEM" "$g_sm" "$R" "$CMEM" "$s_mem_pct" "$R"
  printf '%b⊳ system %b   %bCPU%b %b%s%b %b%3s%%%b   %bMEM%b %b%s%b %b%3s%%%b  %b· 30m▸now%b\n' \
    "$SESS_BOLD$CSYS" "$R" "$CDIM" "$R" "$CCPU" "$g_yc" "$R" "$CCPU" "$sys_cpu_v" "$R" \
    "$CDIM" "$R" "$CMEM" "$g_ym" "$R" "$CMEM" "$sys_mem_pct" "$R" "$CDIM" "$R"
}

# ---------- stacked block bars ----------------------------------------------
_bar() { # args: pct width -> "<filled>\t<rest>" (tab-separated)
  awk -v p="$1" -v w="$2" 'BEGIN{
    if(p>100)p=100; if(p<0)p=0; f=int(p/100*w+0.5)
    s=""; for(i=0;i<f;i++)s=s"█"; r=""; for(i=f;i<w;i++)r=r"░"; printf "%s\t%s", s, r }'
}
# Pie view, "unrolled": each metric as a proportional fill bar, same two-line
# session/system layout with CPU then MEM going right.
view_pie() {
  local PW="${AGENT_HUD_PIE_W:-10}"
  local cf cr mf mr
  IFS=$'\t' read -r cf cr <<EOF
$(_bar "$s_cpu" "$PW")
EOF
  IFS=$'\t' read -r mf mr <<EOF
$(_bar "$s_mem_pct" "$PW")
EOF
  printf '%b⊳ session%b   %bCPU%b %b%s%b%b%s%b %b%3s%%%b   %bMEM%b %b%s%b%b%s%b %b%3s%%%b\n' \
    "$SESS_BOLD$CSESS" "$R" "$CDIM" "$R" "$CCPU" "$cf" "$R" "$CDIM" "$cr" "$R" "$CCPU" "$s_cpu" "$R" \
    "$CDIM" "$R" "$CMEM" "$mf" "$R" "$CDIM" "$mr" "$R" "$CMEM" "$s_mem_pct" "$R"
  IFS=$'\t' read -r cf cr <<EOF
$(_bar "$sys_cpu_v" "$PW")
EOF
  IFS=$'\t' read -r mf mr <<EOF
$(_bar "$sys_mem_pct" "$PW")
EOF
  printf '%b⊳ system %b   %bCPU%b %b%s%b%b%s%b %b%3s%%%b   %bMEM%b %b%s%b%b%s%b %b%3s%%%b\n' \
    "$SESS_BOLD$CSYS" "$R" "$CDIM" "$R" "$CCPU" "$cf" "$R" "$CDIM" "$cr" "$R" "$CCPU" "$sys_cpu_v" "$R" \
    "$CDIM" "$R" "$CMEM" "$mf" "$R" "$CDIM" "$mr" "$R" "$CMEM" "$sys_mem_pct" "$R"
}

# ---------- render ----------------------------------------------------------
cmd_render() {
  local cwd="$PWD" view=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --cwd)  cwd="$2"; shift 2 ;;
      --view) view="$2"; shift 2 ;;
      *)      shift ;;
    esac
  done
  [ -d "$cwd" ] || cwd="$PWD"
  view="${view:-${AGENT_HUD_VIEW:-classic}}"
  # the lavish views default to the lavish colorway unless one is explicitly set
  if [ "$view" != classic ] && [ -z "${AGENT_HUD_COLORWAY:-}" ] \
     && ! { [ -f "$CONFIG" ] && grep -q '^colorway' "$CONFIG" 2>/dev/null; }; then
    AGENT_HUD_COLORWAY=lavish
  fi
  resolve_colorway

  # session
  local s_cpu s_rss; read -r s_cpu s_rss <<EOF
$(session_stats)
EOF
  # system mem
  local m_used m_total; read -r m_used m_total <<EOF
$(sys_mem)
EOF
  local sys_cpu_v; sys_cpu_v=$(sys_cpu)
  local pwd_h; pwd_h=$(pwd_size "$cwd")
  local d_free d_cap; read -r d_free d_cap <<EOF
$(disk_free "$cwd")
EOF

  # derived strings
  local s_mem_h s_mem_pct sys_mem_str sys_mem_pct
  s_mem_h=$(b2h "${s_rss:-0}")
  s_mem_pct=$(awk -v u="${s_rss:-0}" -v t="${m_total:-1}" 'BEGIN{printf "%d", (t>0)?u/t*100:0}')
  sys_mem_str="$(b2h "${m_used:-0}")/$(b2h "${m_total:-0}")"
  sys_mem_pct=$(awk -v u="${m_used:-0}" -v t="${m_total:-1}" 'BEGIN{printf "%d", (t>0)?u/t*100:0}')

  local sess_mem="${s_mem_h} (${s_mem_pct}%)"
  local sys_mem="${sys_mem_str} (${sys_mem_pct}%)"
  local disk_str="${d_free} free (${d_cap} used)"

  # feed the time-series (used by the graph view) regardless of active view
  record_history "$s_cpu" "$s_mem_pct" "$sys_cpu_v" "$sys_mem_pct"

  case "$view" in
    graph) view_graph; return ;;
    pie)   view_pie;   return ;;
  esac

  # classic two-line HUD (labels padded so columns align with line 2)
  printf '%b⊳ session%b   %bCPU%b %b%4s%%%b   %bMEM%b %b%-18s%b %bpwd %b %b%s%b\n' \
    "$SESS_BOLD$CSESS" "$R" "$CDIM" "$R" "$CCPU" "$s_cpu" "$R" \
    "$CDIM" "$R" "$CMEM" "$sess_mem" "$R" "$CDIM" "$R" "$CSTORE" "$pwd_h" "$R"
  # line 2: system
  printf '%b⊳ system %b   %bCPU%b %b%4s%%%b   %bMEM%b %b%-18s%b %bdisk%b %b%s%b\n' \
    "$SESS_BOLD$CSYS" "$R" "$CDIM" "$R" "$CCPU" "$sys_cpu_v" "$R" \
    "$CDIM" "$R" "$CMEM" "$sys_mem" "$R" "$CDIM" "$R" "$CSTORE" "$disk_str" "$R"
}

# ---------- daemon ----------------------------------------------------------
cmd_daemon() {
  while :; do
    sample_sys_cpu > "$SYS_CACHE.tmp" 2>/dev/null && mv "$SYS_CACHE.tmp" "$SYS_CACHE"
    sleep "$DAEMON_INTERVAL"
  done
}

cmd_colorways() {
  echo "Available colorways (set AGENT_HUD_COLORWAY=<name> or colorway=<name> in $CONFIG):"
  echo "  gruvbox      (default, warm)"
  echo "  catppuccin   (matches Catppuccin Mocha)"
  echo "  tokyonight"
  echo "  lavish       (opulent amethyst + gold; default for graph/pie views)"
  echo "  mono         (labels only)"
}

cmd_help() {
  cat <<EOF
agent-hud — multi-view resource HUD for agent status lines

USAGE
  agent-hud render [--cwd DIR]   print the HUD in the active view (default: classic)
  agent-hud classic [--cwd DIR]  the 2-line session / system HUD
  agent-hud graph  [--cwd DIR]   classic layout w/ braille 30-min time-graphs
  agent-hud pie    [--cwd DIR]   classic layout w/ proportional usage bars
  agent-hud daemon               sample system CPU%% into the cache (run via launchd/systemd)
  agent-hud colorways            list built-in colorways
  agent-hud help

VIEWS
  Pick the statusline view with AGENT_HUD_VIEW=classic|graph|pie (or use the
  subcommands above). graph/pie default to the 'lavish' colorway.

CONFIG
  AGENT_HUD_COLORWAY    colorway name (default: gruvbox)
  AGENT_HUD_VIEW        classic | graph | pie (default: classic)
  AGENT_HUD_GRAPH_W     per-metric braille graph width (cells)           [16]
  AGENT_HUD_PIE_W       per-metric usage bar width (cells)               [10]
  AGENT_HUD_HIST_WINDOW time span of the graph in seconds                [1800]
  AGENT_HUD_HIST_STEP   min seconds between recorded samples             [5]
  $CONFIG               optional, e.g.  colorway=lavish
EOF
}

case "${1:-render}" in
  render)    shift; cmd_render "$@" ;;
  classic)   shift; cmd_render --view classic "$@" ;;
  graph)     shift; cmd_render --view graph "$@" ;;
  pie)       shift; cmd_render --view pie "$@" ;;
  daemon)    cmd_daemon ;;
  colorways) cmd_colorways ;;
  help|-h|--help) cmd_help ;;
  *) cmd_render "$@" ;;
esac
